msgstr ""

#. [part]
#: Girl_unDead/scenarios/05_Puppeteer.cfg:70
msgid "Malica had defeated the enemy, but she had failed to find the truth. She knew only that the mages of Wesnoth wanted elvish shamans and herself."
msgstr ""

#. [part]
#: Girl_unDead/scenarios/05_Puppeteer.cfg:74
msgid ""
"<span font='24'>Puppeteer</span>\n"
"<span font='16'>S5</span>"
msgstr ""

#. [part]
#: Girl_unDead/scenarios/05_Puppeteer.cfg:76
msgid "She and her soldiers traveled toward the capital to rescue the shamans and to learn why they wanted her."
msgstr ""

#. [objective]: condition=win
#: Girl_unDead/scenarios/05_Puppeteer.cfg:85
msgid "Defeat the leader of the royal army"
msgstr ""

#. [objective]: condition=win
#: Girl_unDead/scenarios/05_Puppeteer.cfg:90
msgid "Defeat the leader of desperado"
msgstr ""

#. [objective]: condition=win
#: Girl_unDead/scenarios/05_Puppeteer.cfg:90
msgid "(special bonus)"
msgstr ""

#. [objective]: condition=lose
#: Girl_unDead/scenarios/05_Puppeteer.cfg:110
#: Girl_unDead/scenarios/06_Gulf.cfg:294
#: Girl_unDead/scenarios/07_Sanctuary.cfg:261
#: Girl_unDead/scenarios/07_Sanctuary.cfg:642
#: Girl_unDead/scenarios/09_Intrusion.cfg:290
#: Girl_unDead/scenarios/10_Castle.cfg:293
#: Girl_unDead/scenarios/10_Castle.cfg:735
#: Girl_unDead/scenarios/10_Castle.cfg:898
#: Girl_unDead/scenarios/10_Castle.cfg:1071
msgid "Death of Runt"
msgstr ""

#. [message]: speaker=Cyclos
#: Girl_unDead/scenarios/05_Puppeteer.cfg:172
msgid "A stench of death has been in the air for quite a while."
msgstr ""

#. [message]: speaker=Stella
#: Girl_unDead/scenarios/05_Puppeteer.cfg:176
msgid "I am aware of it too."
msgstr ""

#. [message]: speaker=Poet
#: Girl_unDead/scenarios/05_Puppeteer.cfg:180
msgid "It may be odor of our Princess."
msgstr ""

#. [message]: speaker=Malica
#: Girl_unDead/scenarios/05_Puppeteer.cfg:184
msgid "Poet! That's horrible. Cyclos, you don't think that, do you?"
msgstr ""

#. [message]: speaker=Cyclos
#: Girl_unDead/scenarios/05_Puppeteer.cfg:188
msgid "Um, you do smell a little after the rain..."
msgstr ""

#. [message]: speaker=Malica
#. [message]: speaker=Mermaid Princess
#: Girl_unDead/scenarios/05_Puppeteer.cfg:192
#: Girl_unDead/scenarios/06_Gulf.cfg:422
#: Girl_unDead/scenarios/06_Gulf.cfg:520
msgid "No!"
msgstr ""

#. [message]: speaker=Stella
#: Girl_unDead/scenarios/05_Puppeteer.cfg:196
msgid "Cyclos, you should be more circumspect when you speak."
msgstr ""

#. [message]: speaker=Cyclos
#: Girl_unDead/scenarios/05_Puppeteer.cfg:200
msgid "Yes, I am sorry."
msgstr ""

#. [message]: speaker=Poet
#: Girl_unDead/scenarios/05_Puppeteer.cfg:204
msgid "Cyclos, you are insensitive. Stella, you agree, don't you?"
msgstr ""

#. [message]: speaker=Stella
#: Girl_unDead/scenarios/05_Puppeteer.cfg:208
msgid "It's not for me to say."
msgstr ""

#. [message]: speaker=Poet
#: Girl_unDead/scenarios/05_Puppeteer.cfg:212
msgid "There are many corpses about. These may be the cause of the odor. Something has happened here."
msgstr ""

#. [message]: speaker=Cyclos
#: Girl_unDead/scenarios/05_Puppeteer.cfg:216
msgid "They are annoying. I'll breke them."
msgstr ""

#. [message]: speaker=Poet
#: Girl_unDead/scenarios/05_Puppeteer.cfg:220
msgid "We must be careful around them."
msgstr ""

#. [message]: speaker=Malica
#: Girl_unDead/scenarios/05_Puppeteer.cfg:224
msgid "I feel unpleasant too."
msgstr ""

#. [message]: speaker=Kingdom
#: Girl_unDead/scenarios/05_Puppeteer.cfg:232
msgid "Men, look about. There are many corpses, so the one we seek must be near. Oh, and there is the woman lich... catch her."
msgstr ""

#. [message]: speaker=Bandit
#: Girl_unDead/scenarios/05_Puppeteer.cfg:236
msgid "Hey, do you still agree to let us join your army if we attack these corpses?"
msgstr ""

#. [message]: speaker=Kingdom
#: Girl_unDead/scenarios/05_Puppeteer.cfg:240
msgid "Yes, but don't kill the woman lich."
msgstr ""

#. [message]: speaker=Bandit
#: Girl_unDead/scenarios/05_Puppeteer.cfg:244
msgid "Okay."
msgstr ""

#. [message]: speaker=Malica
#: Girl_unDead/scenarios/05_Puppeteer.cfg:248
msgid "We have no choice but to fight this army."
msgstr ""

#. [message]: speaker=Poet
#: Girl_unDead/scenarios/05_Puppeteer.cfg:252
msgid "That's good."
msgstr ""

#. [message]: speaker=unit
#: Girl_unDead/scenarios/05_Puppeteer.cfg:267
msgid "Corpse, rest in peace!"
msgstr ""

#. [message]: speaker=Puppeteer
#: Girl_unDead/scenarios/05_Puppeteer.cfg:295
msgid "One is a fool to touch any of my puppets."
msgstr ""

#. [message]: speaker=Poet
#: Girl_unDead/scenarios/05_Puppeteer.cfg:299
msgid "Damn it! That is Puppeteer, a troublesome enemy."
msgstr ""

#. [message]: speaker=Cyclos
#: Girl_unDead/scenarios/05_Puppeteer.cfg:303
msgid "Why is he trouble?"
msgstr ""

#. [message]: speaker=Poet
#: Girl_unDead/scenarios/05_Puppeteer.cfg:307
msgid "You will soon know. We must kill him to survive."
msgstr ""

#. [message]: speaker=Kingdom
#: Girl_unDead/scenarios/05_Puppeteer.cfg:311
#: Girl_unDead/scenarios/05_Puppeteer.cfg:368
msgid "There is Puppeteer. Catch him!"
msgstr ""

#. [message]: speaker=unit
#: Girl_unDead/scenarios/05_Puppeteer.cfg:330
msgid "Die, dirty corpse!"
msgstr ""

#. [message]: speaker=Puppeteer
#: Girl_unDead/scenarios/05_Puppeteer.cfg:364
msgid "So you have found me, but you will regret having done so."
msgstr ""

#. [message]: speaker=Poet
#: Girl_unDead/scenarios/05_Puppeteer.cfg:372
msgid "That is Puppeteer! His army is quite troublesome."
msgstr ""

#. [message]: speaker=Cyclos
#: Girl_unDead/scenarios/05_Puppeteer.cfg:376
msgid "He does not look so dangerous."
msgstr ""

#. [message]: speaker=Poet
#: Girl_unDead/scenarios/05_Puppeteer.cfg:380
msgid "You will quickly learn that he is."
msgstr ""

#. [message]: speaker=Puppeteer
#: Girl_unDead/scenarios/05_Puppeteer.cfg:393
msgid "You are Malica, are you not?"
msgstr ""

#. [message]: speaker=Malica
#: Girl_unDead/scenarios/05_Puppeteer.cfg:397
msgid "Why do you know me?"
msgstr ""

#. [message]: speaker=Puppeteer
#: Girl_unDead/scenarios/05_Puppeteer.cfg:401
msgid "There is no time to explain, but I will say that you mother is alive. She is in the king's castle. Only I can tell your mother is alive. Go to the King's castle."
msgstr ""

#. [message]: speaker=Malica
#: Girl_unDead/scenarios/05_Puppeteer.cfg:412
msgid "Please tell me more! He... died..."
msgstr ""

#. [message]: speaker=Stella
#: Girl_unDead/scenarios/05_Puppeteer.cfg:423
msgid "Ah! My arms hurt!"
msgstr ""

#. [effect]
#. [object]
#: Girl_unDead/scenarios/05_Puppeteer.cfg:436
#: Girl_unDead/scenarios/05_Puppeteer.cfg:426
#: Girl_unDead/scenarios/05_Puppeteer.cfg:652
#: Girl_unDead/scenarios/05_Puppeteer.cfg:642
msgid "cursed bow"
msgstr ""

#. [message]: speaker=Poet
#: Girl_unDead/scenarios/05_Puppeteer.cfg:450
msgid "You have been cursed during this battle. Now you must be careful when you attack anyone."
msgstr ""

#. [message]: speaker=$second_unit.id
#: Girl_unDead/scenarios/05_Puppeteer.cfg:473
msgid "Oh! It revived!"
msgstr ""

#. [message]: speaker=Poet
#: Girl_unDead/scenarios/05_Puppeteer.cfg:477
msgid "That is his strength. As long as he lives, the corpses will revive."
msgstr ""

#. [message]: speaker=Cyclos
#: Girl_unDead/scenarios/05_Puppeteer.cfg:481
msgid "Hmmm... his losses are not losses."
msgstr ""

#. [message]: speaker=Kingdom
#: Girl_unDead/scenarios/05_Puppeteer.cfg:509
msgid "Alas! I should have been bringing the eivish shamans from the sanctuary..."
msgstr ""

#. [message]: speaker=Cyclos
#. [message]: speaker=Malica
#. [message]: speaker=Poet
#: Girl_unDead/scenarios/05_Puppeteer.cfg:513
#: Girl_unDead/scenarios/05_Puppeteer.cfg:570
#: Girl_unDead/scenarios/10x_Epilogue.cfg:151
msgid "What?"
msgstr ""

#. [message]: speaker=Kingdom
#: Girl_unDead/scenarios/05_Puppeteer.cfg:518
msgid "Our mages are experimenting using elvish shamans in the sanctuary near here."
msgstr ""

#. [message]: speaker=Cyclos
#: Girl_unDead/scenarios/05_Puppeteer.cfg:522
msgid "What a terrible thing it is!"
msgstr ""

#. [message]: speaker=Bandit
#: Girl_unDead/scenarios/05_Puppeteer.cfg:534
msgid "The Wesnothians has lost. Let's get out of here!"
msgstr ""

#. [message]: speaker=Puppeteer
#: Girl_unDead/scenarios/05_Puppeteer.cfg:550
msgid "Now, I'm free from the Kingdom. And it is no use to battle each other we undead. Don't you think so, lady lich?"
msgstr ""

#. [message]: speaker=Malica
#: Girl_unDead/scenarios/05_Puppeteer.cfg:554
msgid "Yes, I think so, too."
msgstr ""

#. [message]: speaker=Puppeteer
#: Girl_unDead/scenarios/05_Puppeteer.cfg:558
msgid "You must be Malica, daughter of Veronica and niece of Varas."
msgstr ""

#. [message]: speaker=Malica
#: Girl_unDead/scenarios/05_Puppeteer.cfg:562
msgid "How do you know my name? My mother, however, was Nina and Varas was my father."
msgstr ""

#. [message]: speaker=Puppeteer
#: Girl_unDead/scenarios/05_Puppeteer.cfg:566
msgid "Veronica was the real name of your mother. She was Varas's sister."
msgstr ""

#. [message]: speaker=Puppeteer
#: Girl_unDead/scenarios/05_Puppeteer.cfg:574
msgid "Yes, it is true. I shall tell you what I know about it ..."
msgstr ""

#. [message]: speaker=narrator
#: Girl_unDead/scenarios/05_Puppeteer.cfg:579
msgid "Puppeteer explained that when he was young, there were three white mages with the potential to become the king's high mage: Varas, Veronica, and Maltos."
msgstr ""

#. [message]: speaker=narrator
#: Girl_unDead/scenarios/05_Puppeteer.cfg:584
msgid "Randolf, the great mage of Wesnoth, was their teacher."
msgstr ""

#. [message]: speaker=narrator
#: Girl_unDead/scenarios/05_Puppeteer.cfg:589
msgid "One day, Varas and Veronica experimented with a magical spell suggested by Randolf. It went wrong and Veronica became immortal while Varas became undead. The two then disappeared. Maltos, who had loved Veronica, then turned to dark mage and became the Puppeteer."
msgstr ""

#. [message]: speaker=narrator
#: Girl_unDead/scenarios/05_Puppeteer.cfg:594
msgid "Randolf desired immortality. He searched for Veronica, your mother Nina, many years and when finally he believed he found her, he caused the daughter to die because he knew that Veronica's clan had the secret of how to revive the dead. Randolf then misled Puppeteer into thinking that all the people of the village must be killed if Veronica was to be safe."
msgstr ""

#. [message]: speaker=narrator
#: Girl_unDead/scenarios/05_Puppeteer.cfg:599
msgid "Randolf did regain youthfulness through the power of Veronica, but this was not yet immortality. Randolf then discovered that Malica was with Varas and he paid some orcs to seize her. As part of his plan he felt he needed the healing power of elvish shamans, so he seized some and began to experiment. In time Puppeteer figured out that Randolf had deceived him and had turned all the white mages against him."
msgstr ""

#. [message]: speaker=Puppeteer
#: Girl_unDead/scenarios/05_Puppeteer.cfg:603
msgid "The elvish shamans are imprisoned in a sanctuary near here. Malica, your mother is in the king's castle."
msgstr ""

#. [message]: speaker=Malica
#: Girl_unDead/scenarios/05_Puppeteer.cfg:607
msgid "My mother alive! Thank you... Thank you so much. First we'll rescue the shamans, then we go to Weldyn."
msgstr ""

#. [message]: speaker=Puppeteer
#: Girl_unDead/scenarios/05_Puppeteer.cfg:611
msgid "I shall bestow a special skill on an archer."
msgstr ""

#. [message]: speaker=Stella
#: Girl_unDead/scenarios/05_Puppeteer.cfg:615
msgid "I am... an excellent archer."
msgstr ""

#. [message]: speaker=Puppeteer
#: Girl_unDead/scenarios/05_Puppeteer.cfg:619
msgid "This skill is meant for neither human nor elf. It is cursed with spells of the chaos."
msgstr ""

#. [message]: speaker=Stella
#: Girl_unDead/scenarios/05_Puppeteer.cfg:623
msgid "I care not. Please give me it."
msgstr ""

#. [message]: speaker=Cyclos
#: Girl_unDead/scenarios/05_Puppeteer.cfg:627
msgid "Stella? Think about this..."
msgstr ""

#. [message]: speaker=Poet
#: Girl_unDead/scenarios/05_Puppeteer.cfg:631
msgid "I think this skill will not be good for you."
msgstr ""

#. [message]: speaker=Stella
#: Girl_unDead/scenarios/05_Puppeteer.cfg:635
msgid "I gladly take this risk to help Cyclos... and our tribe."
msgstr ""

#. [message]: speaker=Puppeteer
#: Girl_unDead/scenarios/05_Puppeteer.cfg:639
msgid "I see. I'll give it to you. But be aware that it will erode both mind and body over time."
msgstr ""

#. [message]: speaker=Malica
#: Girl_unDead/scenarios/05_Puppeteer.cfg:666
msgid "I really want to get to Weldyn, but since the sanctuary is near, we'll go there first."
msgstr ""

#. [message]: speaker=Puppeteer
#: Girl_unDead/scenarios/05_Puppeteer.cfg:670
msgid "Pray for good fortune in this war."
msgstr ""

#. [message]: speaker=Malica
#: Girl_unDead/scenarios/05_Puppeteer.cfg:742
msgid "What's that?"
msgstr ""

#. [message]: speaker=Poet
#: Girl_unDead/scenarios/05_Puppeteer.cfg:750
msgid "Oh! It's the legendary ring of the Gold Angel."
msgstr ""

#. [message]: type=Gold Chocobone
#. [message]: type=Silver Chocobone
#. [message]: type=Dread Bat
#: Girl_unDead/scenarios/05_Puppeteer.cfg:758
#: Girl_unDead/scenarios/05_Puppeteer.cfg:777
#: Girl_unDead/scenarios/05_Puppeteer.cfg:796
msgid "I'll follow you forever."
msgstr ""

#. [message]: speaker=Malica
#: Girl_unDead/scenarios/05_Puppeteer.cfg:762
msgid "You should be very useful in battle."
msgstr ""

#. [message]: speaker=Poet
#: Girl_unDead/scenarios/05_Puppeteer.cfg:769
msgid "Ah! It's the legendary ring of the Silver Angel."
msgstr ""

#. [message]: speaker=Malica
#: Girl_unDead/scenarios/05_Puppeteer.cfg:781
msgid "You should be useful in battle."
msgstr ""

#. [message]: speaker=Poet
#: Girl_unDead/scenarios/05_Puppeteer.cfg:788
msgid "Hum, it's a ordinary ring."
msgstr ""

#. [message]: speaker=Malica
#: Girl_unDead/scenarios/05_Puppeteer.cfg:800
msgid "I doubt you will be much help..."
msgstr ""

#. [scenario]: id=06_Gulf
#: Girl_unDead/scenarios/06_Gulf.cfg:5
msgid "Gulf"
msgstr ""

#. [part]
#: Girl_unDead/scenarios/06_Gulf.cfg:17
msgid ""
"<span font='24'>Gulf</span>\n"
"<span font='16'>S6</span>"
msgstr ""

#. [side]: id=Merman King, type=Merman Triton
#. [side]: id=Mermaid Princess, type=Mermaid Enchantress
#. [side]
#: Girl_unDead/scenarios/06_Gulf.cfg:115
#: Girl_unDead/scenarios/06_Gulf.cfg:128
#: Girl_unDead/scenarios/09_Intrusion.cfg:240
msgid "Merfolk"
msgstr ""

#. [objective]: condition=win
#: Girl_unDead/scenarios/06_Gulf.cfg:274
msgid "Reach Malica to the signpost"
msgstr ""

#. [message]: speaker=Poet
#: Girl_unDead/scenarios/06_Gulf.cfg:330
msgid "My Princess, we must cross this gulf to reach the sanctuary."
msgstr ""

#. [message]: speaker=Malica
#: Girl_unDead/scenarios/06_Gulf.cfg:337
msgid "All right... How do you know so much about these lands?"
msgstr ""

#. [message]: speaker=Poet
#: Girl_unDead/scenarios/06_Gulf.cfg:341
msgid "Uh... I can't hear you because of the wind... Look! There are enemies in our way!"
msgstr ""

#. [message]: speaker=Kingdom
#: Girl_unDead/scenarios/06_Gulf.cfg:345
msgid "Fight these undead with us."
msgstr ""

#. [message]: speaker=Merman King
#: Girl_unDead/scenarios/06_Gulf.cfg:349
msgid "Yes, we will. We have long been your allies."
msgstr ""

#. [message]: speaker=Mermaid Princess
#: Girl_unDead/scenarios/06_Gulf.cfg:353
msgid "But this woman leading the undead hasn't harmed us, my father. It is strange she fights against the mighty Kingdom with a small army. I think there might be a reason she shuld get to Weldyn..."
msgstr ""

#. [message]: speaker=Merman King
#: Girl_unDead/scenarios/06_Gulf.cfg:357
msgid "All undead are evil and must be destroyed."
msgstr ""

#. [message]: speaker=Mermaid Princess
#: Girl_unDead/scenarios/06_Gulf.cfg:361
msgid "I see."
msgstr ""

#. [message]: speaker=Kingdom
#: Girl_unDead/scenarios/06_Gulf.cfg:365
msgid "Good. I'm counting on you."
msgstr ""

#. [message]: speaker=Poet
#: Girl_unDead/scenarios/06_Gulf.cfg:369
msgid "Ha, let's kill all of them!"
msgstr ""

#. [message]: speaker=Malica
#: Girl_unDead/scenarios/06_Gulf.cfg:373
msgid "No! We need only cross the gulf. Don't kill too much."
msgstr ""

#. [message]: speaker=Stella
#: Girl_unDead/scenarios/06_Gulf.cfg:389
msgid "Great! I'm far more accurate with a bow now."
msgstr ""

#. [message]: speaker=Poet
#: Girl_unDead/scenarios/06_Gulf.cfg:393
msgid "Don't celebrate. You will soon see the curse's effect."
msgstr ""

#. [message]: speaker=Stella
#: Girl_unDead/scenarios/06_Gulf.cfg:407
msgid "No! I killed him, yet he walks..."
msgstr ""

#. [message]: speaker=Poet
#: Girl_unDead/scenarios/06_Gulf.cfg:411
msgid "I warned you of the curse. Now you know the cost."
msgstr ""

#. [message]: speaker=Merman King
#: Girl_unDead/scenarios/06_Gulf.cfg:433
msgid "Ah! My daughter! Undead, I will never forgive you!"
msgstr ""

#. [message]: speaker=Merman King
#: Girl_unDead/scenarios/06_Gulf.cfg:516
msgid "Ugh!"
msgstr ""

#. [message]: speaker=Merman King
#: Girl_unDead/scenarios/06_Gulf.cfg:530
msgid "Undead... please don't kill my dauther."
msgstr ""

#. [message]: speaker=Poet
#: Girl_unDead/scenarios/06_Gulf.cfg:534
msgid "Hah! I like fishing too much to stop now."
msgstr ""

#. [message]: speaker=Malica
#: Girl_unDead/scenarios/06_Gulf.cfg:539
msgid "Stop your joking, Poet. We will allow your daughter to live if she stops fighting."
msgstr ""

#. [message]: speaker=Merman King
#: Girl_unDead/scenarios/06_Gulf.cfg:544
msgid "Thank you."
msgstr ""

#. [message]: speaker=Mermaid Princess
#: Girl_unDead/scenarios/06_Gulf.cfg:548
msgid "I have no reason to fight you. I am leaving."
msgstr ""

#. [message]: speaker=Kingdom
#: Girl_unDead/scenarios/06_Gulf.cfg:559
#: Girl_unDead/scenarios/06_Gulf.cfg:646
msgid "Mermen! Don't run!"
msgstr ""

#. [message]: speaker=Poet
#: Girl_unDead/scenarios/06_Gulf.cfg:563
#: Girl_unDead/scenarios/06_Gulf.cfg:650
msgid "Ha! Of course, mermen don't run, they swim!"
msgstr ""

#. [message]: speaker=Mermaid Princess
#: Girl_unDead/scenarios/06_Gulf.cfg:581
msgid "Lady lich, you don't seem evil. I see no reason to fight you... Bye."
msgstr ""

#. [message]: speaker=Malica
#: Girl_unDead/scenarios/06_Gulf.cfg:614
msgid "We got through. Now to the sanctuary."
msgstr ""

#. [message]: speaker=Mermaid Princess
#: Girl_unDead/scenarios/06_Gulf.cfg:623
msgid "Lady lich, you don't look so wrong. We have no reason to battle each other... Bye."
msgstr ""

#. [scenario]: id=07_Sanctuary
#: Girl_unDead/scenarios/07_Sanctuary.cfg:5
msgid "Sanctuary"
msgstr ""

#. [part]
#: Girl_unDead/scenarios/07_Sanctuary.cfg:21
msgid ""
"<span font='24'>Sanctuary</span>\n"
"<span font='16'>S7</span>"
msgstr ""

#. [side]: id=White Mage, type=Mage of Light
#. [side]: id=Great Mage, type=Great Mage
#: Girl_unDead/scenarios/07_Sanctuary.cfg:119
#: Girl_unDead/scenarios/07_Sanctuary.cfg:131
msgid "Mages"
msgstr ""

#. [side]
#: Girl_unDead/scenarios/07_Sanctuary.cfg:230
msgid "Fallen"
msgstr ""

#. [objective]: condition=win
#: Girl_unDead/scenarios/07_Sanctuary.cfg:241
#: Girl_unDead/scenarios/07_Sanctuary.cfg:622
msgid "Defeat all enemy leaders"
msgstr ""

#. [message]: speaker=Cyclos
#: Girl_unDead/scenarios/07_Sanctuary.cfg:296
msgid "That structure looks more like a fortress than a temple."
msgstr ""

#. [message]: speaker=Poet
#: Girl_unDead/scenarios/07_Sanctuary.cfg:300
msgid "This region is as bright as the day though it is not yet dawn. Also, I can't know the layout of the building."
msgstr ""

#. [message]: speaker=Malica
#: Girl_unDead/scenarios/07_Sanctuary.cfg:304
msgid "I sense strong magic here. The mages may be creating this light."
msgstr ""

#. [message]: speaker=Poet
#: Girl_unDead/scenarios/07_Sanctuary.cfg:308
msgid "Will it hinder us?"
msgstr ""

#. [message]: speaker=Malica
#: Girl_unDead/scenarios/07_Sanctuary.cfg:312
msgid "I don't know. I do know that we will be unwelcome."
msgstr ""

#. [event]
#: Girl_unDead/scenarios/07_Sanctuary.cfg:322
msgid "Hendrich"
msgstr ""

#. [message]: speaker=Hendrich
#: Girl_unDead/scenarios/07_Sanctuary.cfg:325
msgid "Not kill me! Please forgive me!"
msgstr ""

#. [message]: speaker=Poet
#: Girl_unDead/scenarios/07_Sanctuary.cfg:329
msgid "Here is a smelly human mage."
msgstr ""

#. [message]: speaker=Malica
#: Girl_unDead/scenarios/07_Sanctuary.cfg:333
msgid "Are you hiding yourself from us?"
msgstr ""

#. [message]: speaker=Hendrich
#: Girl_unDead/scenarios/07_Sanctuary.cfg:337
msgid "No. I'm escaping from the temple."
msgstr ""

#. [message]: speaker=Malica
#: Girl_unDead/scenarios/07_Sanctuary.cfg:341
msgid "Why?"
msgstr ""

#. [message]: speaker=Hendrich
#: Girl_unDead/scenarios/07_Sanctuary.cfg:345
msgid "The Kingdom is doing abomination experiments with elvish shamans as materials. I could not bear it."
msgstr ""

#. [message]: speaker=Cyclos
#: Girl_unDead/scenarios/07_Sanctuary.cfg:349
msgid "Oh! Loana! I will break the front of the temple even now and go to rescue you."
msgstr ""

#. [message]: speaker=Hendrich
#: Girl_unDead/scenarios/07_Sanctuary.cfg:353
msgid "The front gate is very solid, but the back door protection is loose."
msgstr ""

#. [message]: speaker=Malica
#: Girl_unDead/scenarios/07_Sanctuary.cfg:368
msgid "Thank you. What do you do after?"
msgstr ""

#. [message]: speaker=Hendrich
#: Girl_unDead/scenarios/07_Sanctuary.cfg:372
msgid "Despite being undead, you look better than a human being. I want to be your help."
msgstr ""

#. [message]: speaker=Malica
#: Girl_unDead/scenarios/07_Sanctuary.cfg:376
msgid "It will be good."
msgstr ""

#. [message]: speaker=Poet
#: Girl_unDead/scenarios/07_Sanctuary.cfg:380
msgid "Damm, do it on your own."
msgstr ""

#. [message]: speaker=Cyclos
#: Girl_unDead/scenarios/07_Sanctuary.cfg:399
msgid "The shroud is cleared."
msgstr ""

#. [message]: speaker=Malica
#: Girl_unDead/scenarios/07_Sanctuary.cfg:403
msgid "It is certainly thanks to Hendrich."
msgstr ""

#. [message]: speaker=Poet
#: Girl_unDead/scenarios/07_Sanctuary.cfg:407
msgid "Sometimes even a mage can be useful.."
msgstr ""

#. [message]: speaker=Hendrich
#: Girl_unDead/scenarios/07_Sanctuary.cfg:411
msgid "I will do my best and I will be more helpful."
msgstr ""

#. [message]: speaker=Poet
#: Girl_unDead/scenarios/07_Sanctuary.cfg:427
msgid "Oh, it's dazzling! Withdraw the previous word!"
msgstr ""

#. [unit]: id=Loana, type=Elvish Shyde
#. [unit]: type=Soulless, id=Loana Dead
#: Girl_unDead/scenarios/07_Sanctuary.cfg:600
#: Girl_unDead/scenarios/07_Sanctuary.cfg:1146
#: Girl_unDead/scenarios/07_Sanctuary.cfg:1259
msgid "Loana"
msgstr ""

#. [message]: speaker=Cyclos
#: Girl_unDead/scenarios/07_Sanctuary.cfg:612
msgid "Loana! I've come to save you!"
msgstr ""

#. [message]: speaker=Loana
#: Girl_unDead/scenarios/07_Sanctuary.cfg:617
msgid "Cyclos! Thank you, I have hoped to see you for quite some time. Unfortunately, we cannot now return with you. The hideous experiments we have suffered have made that impossible. We will, however, fight alongside you so long as we can."
msgstr ""

#. [objective]: condition=lose
#: Girl_unDead/scenarios/07_Sanctuary.cfg:646
msgid "Death of Loana"
msgstr ""

#. [message]: speaker=Cyclos
#: Girl_unDead/scenarios/07_Sanctuary.cfg:758
#: Girl_unDead/scenarios/07_Sanctuary.cfg:883
#: Girl_unDead/scenarios/07_Sanctuary.cfg:1008
msgid "Why there are so many corpses?"
msgstr ""

#. [message]: speaker=Loana
#: Girl_unDead/scenarios/07_Sanctuary.cfg:769
#: Girl_unDead/scenarios/07_Sanctuary.cfg:894
#: Girl_unDead/scenarios/07_Sanctuary.cfg:1019
msgid "They once were shamans as me..."
msgstr ""

#. [message]: speaker=Cyclos
#: Girl_unDead/scenarios/07_Sanctuary.cfg:776
#: Girl_unDead/scenarios/07_Sanctuary.cfg:901
#: Girl_unDead/scenarios/07_Sanctuary.cfg:1026
msgid "... No, they were elvish shamans! Why?"
msgstr ""

#. [message]: speaker=$shaman_stored.id
#: Girl_unDead/scenarios/07_Sanctuary.cfg:1080
msgid "Ugh, sore..."
msgstr ""

#. [message]: speaker=$shaman_stored.name
#. [message]: speaker=Loana Dead
#: Girl_unDead/scenarios/07_Sanctuary.cfg:1104
#: Girl_unDead/scenarios/07_Sanctuary.cfg:1156
#: Girl_unDead/scenarios/07_Sanctuary.cfg:1269
msgid "Uuh... Uuh... Uuh..."
msgstr ""

#. [message]: speaker=Loana
#: Girl_unDead/scenarios/07_Sanctuary.cfg:1116
#: Girl_unDead/scenarios/07_Sanctuary.cfg:1229
msgid "Cyclos, thank you again for coming. I love you... but I must now say good bye."
msgstr ""

#. [message]: speaker=Cyclos
#: Girl_unDead/scenarios/07_Sanctuary.cfg:1120
#: Girl_unDead/scenarios/07_Sanctuary.cfg:1233
msgid "Loana! Think! There must be some cure. We'll go back home and figure this out!"
msgstr ""

#. [message]: speaker=Loana
#: Girl_unDead/scenarios/07_Sanctuary.cfg:1124
#: Girl_unDead/scenarios/07_Sanctuary.cfg:1237
msgid "I thank you, but my time is over. Good bye, Cyclos... Ugh!"
msgstr ""

#. [message]: speaker=Cyclos
#: Girl_unDead/scenarios/07_Sanctuary.cfg:1160
#: Girl_unDead/scenarios/07_Sanctuary.cfg:1273
msgid "Loana... Why did it have to be you..."
msgstr ""

#. [message]: speaker=Malica
#: Girl_unDead/scenarios/07_Sanctuary.cfg:1164
#: Girl_unDead/scenarios/07_Sanctuary.cfg:1277
msgid "Be gone! All corpses by my hand!"
msgstr ""

#. [message]: speaker=Malica
#: Girl_unDead/scenarios/07_Sanctuary.cfg:1197
msgid "Was what I did necessary? I'm sorry, Cyclos, but corpses lose the memories of their former life. They exist only in pain."
msgstr ""

#. [message]: speaker=Cyclos
#: Girl_unDead/scenarios/07_Sanctuary.cfg:1201
msgid "I know... Poet, our agreement is fulfilled. Kill me... please!"
msgstr ""

#. [message]: speaker=Malica
#: Girl_unDead/scenarios/07_Sanctuary.cfg:1205
msgid "No! Your life is now mine. I will decide when you die. You elves need rest and I need to rebuild my army. Is there a place nearby where we can hide?"
msgstr ""

#. [message]: speaker=Poet
#: Girl_unDead/scenarios/07_Sanctuary.cfg:1209
msgid "At the foot of the Heart Mountains there is a place which human will not go. They believe dangerous creatures exist there."
msgstr ""

#. [message]: speaker=Malica
#: Girl_unDead/scenarios/07_Sanctuary.cfg:1213
msgid "Poet, lead the way."
msgstr ""

#. [message]: speaker=Cyclos
#: Girl_unDead/scenarios/07_Sanctuary.cfg:1308
msgid "Loana, no!"
msgstr ""

#. [scenario]: id=08_A_Long_Day
#: Girl_unDead/scenarios/08_A_Long_Day.cfg:5
msgid "A Long Day"
msgstr ""

#. [side]
#: Girl_unDead/scenarios/08_A_Long_Day.cfg:44
msgid "Snow Monsters"
msgstr ""

#. [part]
#: Girl_unDead/scenarios/08_A_Long_Day.cfg:58
msgid "Because Cyclos was sad from the loss of Loana and the other elves were tired from the fighting, they retreated into the mountains."
msgstr ""

#. [part]
#: Girl_unDead/scenarios/08_A_Long_Day.cfg:62
msgid "The freed shamans, strange to say, had ceased turning into undead. It was thought that Malica's magical powers had cured them."
msgstr ""

#. [part]
#: Girl_unDead/scenarios/08_A_Long_Day.cfg:66
msgid ""
"<span font='24'>A Long Day</span>\n"
"<span font='16'>S8</span>"
msgstr ""

#. [part]
#: Girl_unDead/scenarios/08_A_Long_Day.cfg:68
msgid "Although the shamans had been cured, their magical gift had turned toward something darkness."
msgstr ""

#. [objective]: condition=win
#: Girl_unDead/scenarios/08_A_Long_Day.cfg:77
msgid "Kill the animals"
msgstr ""

#. [message]: speaker=Cyclos
#: Girl_unDead/scenarios/08_A_Long_Day.cfg:120
msgid "Are you sure this is a safe place to hide?"
msgstr ""

#. [message]: speaker=Poet
#: Girl_unDead/scenarios/08_A_Long_Day.cfg:124
msgid "People fear this place, so few come. But we may face some monsters."
msgstr ""

#. [message]: speaker=Malica
#: Girl_unDead/scenarios/08_A_Long_Day.cfg:128
msgid "We will rest here, but station guards at the entrance of this valley just in case."
msgstr ""

#. [message]: speaker=Malica
#: Girl_unDead/scenarios/08_A_Long_Day.cfg:132
msgid "Cyclos, the elves need food and I see a bear over there."
msgstr ""

#. [message]: speaker=Cyclos
#: Girl_unDead/scenarios/08_A_Long_Day.cfg:145
msgid "We do not butcher animals for food."
msgstr ""

#. [message]: speaker=Poet
#: Girl_unDead/scenarios/08_A_Long_Day.cfg:149
msgid "You look like you have no energy. Better to hunt so you can regain your vigor."
msgstr ""

#. [message]: speaker=Cyclos
#: Girl_unDead/scenarios/08_A_Long_Day.cfg:153
msgid "I will go. Stella, join me."
msgstr ""

#. [message]: speaker=Stella
#: Girl_unDead/scenarios/08_A_Long_Day.cfg:157
msgid "Yes I will, glad..."
msgstr ""

#. [message]: speaker=Poet
#: Girl_unDead/scenarios/08_A_Long_Day.cfg:161
msgid "<small>Stella! Wait!</small>"
msgstr ""

#. [message]: speaker=Stella
#: Girl_unDead/scenarios/08_A_Long_Day.cfg:165
msgid "Ah... I better stay here to guard this magical bow."
msgstr ""

#. [message]: speaker=Malica
#: Girl_unDead/scenarios/08_A_Long_Day.cfg:169
msgid "Stella! Thank you! Cyclos, let's go."
msgstr ""

#. [message]: speaker=Poet
#: Girl_unDead/scenarios/08_A_Long_Day.cfg:173
msgid "Stella, you did the right thing. Malica knows that you love Cyclos. He is the only who who doesn't know. She has an idea and wanted to be alone with him."
msgstr ""

#. [message]: speaker=Runt
#: Girl_unDead/scenarios/08_A_Long_Day.cfg:177
#: Girl_unDead/scenarios/10x_Epilogue.cfg:118
msgid "???"
msgstr ""

#. [message]: speaker=Poet
#: Girl_unDead/scenarios/08_A_Long_Day.cfg:181
msgid "Now, let's take a break in the ruin."
msgstr ""

#. [message]: speaker=Malica
#: Girl_unDead/scenarios/08_A_Long_Day.cfg:218
msgid "I feel some wonderful power arises when we are together. Don't you?"
msgstr ""

#. [message]: speaker=Cyclos
#: Girl_unDead/scenarios/08_A_Long_Day.cfg:222
msgid "I feel it too. Odd that we are attracted to each other although there is nothing in common between us."
msgstr ""

#. [message]: speaker=Malica
#: Girl_unDead/scenarios/08_A_Long_Day.cfg:226
msgid "Do you think that? Consider that the decoration on your sword is very similar to my..."
msgstr ""

#. [message]: speaker=Cyclos
#: Girl_unDead/scenarios/08_A_Long_Day.cfg:230
msgid "Wait. Let's attack the bear together. I feel somthing will happen then."
msgstr ""

#. [message]: speaker=Malica
#: Girl_unDead/scenarios/08_A_Long_Day.cfg:234
msgid "Sigh... All right."
msgstr ""

#. [message]: speaker=narrator
#: Girl_unDead/scenarios/08_A_Long_Day.cfg:244
msgid "Malica and Cyclos have a coordinated attack that occurs only if the two are adjacent."
msgstr ""

#. [message]: speaker=Cyclos
#: Girl_unDead/scenarios/08_A_Long_Day.cfg:270
#: Girl_unDead/scenarios/08_A_Long_Day.cfg:295
msgid "Oh, a yeti!"
msgstr ""

#. [message]: speaker=Malica
#: Girl_unDead/scenarios/08_A_Long_Day.cfg:274
#: Girl_unDead/scenarios/08_A_Long_Day.cfg:299
msgid "Oh, how much meat can we get from the yeti?"
msgstr ""

#. [message]: speaker=Cyclos
#: Girl_unDead/scenarios/08_A_Long_Day.cfg:278
#: Girl_unDead/scenarios/08_A_Long_Day.cfg:303
msgid "Don't be stupid! It is very dangerous!"
msgstr ""

#. [message]: speaker=Malica
#: Girl_unDead/scenarios/08_A_Long_Day.cfg:314
msgid "We have killed the big beast..."
msgstr ""

#. [message]: speaker=Cyclos
#: Girl_unDead/scenarios/08_A_Long_Day.cfg:318
msgid "Yes, but how do we take it back to our camp?"
msgstr ""

#. [message]: speaker=Malica
#: Girl_unDead/scenarios/08_A_Long_Day.cfg:322
msgid "My soldiers will carry it later. Ah, this is a beautiful place, isn't it?"
msgstr ""

#. [message]: speaker=Cyclos
#: Girl_unDead/scenarios/08_A_Long_Day.cfg:326
msgid "Yes. I would not have thought there was a place like this at the foot of such a steep mountain..."
msgstr ""

#. [message]: speaker=Malica
#: Girl_unDead/scenarios/08_A_Long_Day.cfg:330
msgid "I may forget the terrible battle..."
msgstr ""

#. [message]: speaker=Malica
#: Girl_unDead/scenarios/08_A_Long_Day.cfg:338
msgid "You are thinking of Loana. You would be with her now if we could have rescued her a little earlier... I'm sorry."
msgstr ""

#. [message]: speaker=Cyclos
#: Girl_unDead/scenarios/08_A_Long_Day.cfg:342
msgid "Malica, don't worry. I apologize that I was upset at the time. I still grieve about losing her, yet my heart becomes calm in your presence."
msgstr ""

#. [message]: speaker=Cyclos
#: Girl_unDead/scenarios/08_A_Long_Day.cfg:346
msgid "It is strange that we talk to one another, instead of being enemies."
msgstr ""

#. [message]: speaker=Malica
#: Girl_unDead/scenarios/08_A_Long_Day.cfg:350
msgid "Sure. I dwell in darkness while you belong to a noble race."
msgstr ""

#. [message]: speaker=Cyclos
#: Girl_unDead/scenarios/08_A_Long_Day.cfg:354
msgid "Sometimes I forget you are undead. And sometimes I feel I have long known you."
msgstr ""

#. [message]: speaker=Malica
#: Girl_unDead/scenarios/08_A_Long_Day.cfg:358
msgid "Yes, I feel we have some sort of connection..."
msgstr ""

#. [message]: speaker=Cyclos
#: Girl_unDead/scenarios/08_A_Long_Day.cfg:362
msgid "The sun will soon go down. We must return to camp."
msgstr ""

#. [message]: speaker=Malica
#: Girl_unDead/scenarios/08_A_Long_Day.cfg:366
msgid "... Sorry, I speak too much. Let's go."
msgstr ""

#. [message]: speaker=Cyclos
#. [message]: speaker=unit
#: Girl_unDead/scenarios/08_A_Long_Day.cfg:385
#: Girl_unDead/utils/deaths.cfg:57
msgid "Loana... forgive me..."
msgstr ""

#. [scenario]: id=09_Intrusion
#: Girl_unDead/scenarios/09_Intrusion.cfg:5
msgid "Intrusion"
msgstr ""

#. [part]
#: Girl_unDead/scenarios/09_Intrusion.cfg:23
msgid ""
"<span font='24'>Intrusion</span>\n"
"<span font='16'>S9</span>"
msgstr ""

#. [part]
#: Girl_unDead/scenarios/09_Intrusion.cfg:25
msgid "Because the guards at the king's castle were numerous and strong, Malica used the darkness of the night to sneak into the castle."
msgstr ""

#. [objective]: condition=win
#: Girl_unDead/scenarios/09_Intrusion.cfg:266
msgid "Get as many units as possible through the castle's gate"
msgstr ""

#. [objective]: condition=lose
#: Girl_unDead/scenarios/09_Intrusion.cfg:270
msgid "Malica and the other heros fail to reach the gate"
msgstr ""

#. [note]
#: Girl_unDead/scenarios/09_Intrusion.cfg:302
msgid "Malica must enter last."
msgstr ""

#. [note]
#: Girl_unDead/scenarios/09_Intrusion.cfg:305
msgid "Maximum 23 units, including Malica, can enter the gate."
msgstr ""

#. [message]: speaker=Poet
#: Girl_unDead/scenarios/09_Intrusion.cfg:356
msgid "My Princess, we must enter the gate of the castle before morning."
msgstr ""

#. [message]: speaker=Malica
#: Girl_unDead/scenarios/09_Intrusion.cfg:363
msgid "All right... How do you know about this castle."
msgstr ""

#. [message]: speaker=Poet
#: Girl_unDead/scenarios/09_Intrusion.cfg:367
msgid "Ah... I can't hear you say because it is too cold..."
msgstr ""

#. [message]: speaker=Poet
#: Girl_unDead/scenarios/09_Intrusion.cfg:371
msgid "Anyway the lighthouse lights are dazzling."
msgstr ""

#. [message]: speaker=Hendrich
#: Girl_unDead/scenarios/09_Intrusion.cfg:380
msgid "The great mage is protecting the castle with the fire of that lighthouse."
msgstr ""

#. [message]: speaker=Poet
#: Girl_unDead/scenarios/09_Intrusion.cfg:384
msgid "How?"
msgstr ""

#. [message]: speaker=Hendrich
#: Girl_unDead/scenarios/09_Intrusion.cfg:388
msgid "... Sorry, I've forgotten."
msgstr ""

#. [message]: speaker=Poet
#: Girl_unDead/scenarios/09_Intrusion.cfg:392
msgid "Damm. Poor mage is useless!"
msgstr ""

#. [message]: speaker=Malica
#: Girl_unDead/scenarios/09_Intrusion.cfg:424
#: Girl_unDead/scenarios/09_Intrusion.cfg:784
msgid "Sorry! I can't enter the gate!"
msgstr ""

#. [message]: speaker=Malica
#: Girl_unDead/scenarios/09_Intrusion.cfg:455
msgid "Poet! Don't disappear!"
msgstr ""

#. [message]: speaker=Hendrich
#: Girl_unDead/scenarios/09_Intrusion.cfg:497
#: Girl_unDead/utils/macros.cfg:646
msgid "Oh, I remember! We must put out the fire of all the lighthouses."
msgstr ""

#. [message]: speaker=Hendrich
#: Girl_unDead/scenarios/09_Intrusion.cfg:501
#: Girl_unDead/utils/macros.cfg:651
msgid "The undead that entered the castle will be burnt out by the sacred fire."
msgstr ""

#. [message]: speaker=Malica
#: Girl_unDead/scenarios/09_Intrusion.cfg:548
#: Girl_unDead/scenarios/09_Intrusion.cfg:565
#: Girl_unDead/scenarios/09_Intrusion.cfg:582
msgid "It's midnight now."
msgstr ""

#. [message]: speaker=Poet
#: Girl_unDead/scenarios/09_Intrusion.cfg:600
#: Girl_unDead/scenarios/09_Intrusion.cfg:617
#: Girl_unDead/scenarios/09_Intrusion.cfg:634
msgid "Hurry! The sun rises."
msgstr ""

#. [message]: speaker=Mermaid Princess
#: Girl_unDead/scenarios/09_Intrusion.cfg:675
msgid "Lady lich, do you remember me? I shall build a magical bridge to the castle. You may cross the bridge."
msgstr ""

#. [message]: speaker=Malica
#: Girl_unDead/scenarios/09_Intrusion.cfg:684
msgid "Mermaid Princess, thank you."
msgstr ""

#. [scenario]: id=10_Castle
#: Girl_unDead/scenarios/10_Castle.cfg:5
msgid "Castle"
msgstr ""

#. [part]
#: Girl_unDead/scenarios/10_Castle.cfg:25
msgid ""
"<span font='24'>Castle <small>(Epilogue)</small></span>\n"
"<span font='16'>S10</span>"
msgstr ""

#. [side]: id=Royal Mage, type=Royal Mage
#. [unit]: type=Ghast, id=Rotten Mage
#: Girl_unDead/scenarios/10_Castle.cfg:49
#: Girl_unDead/scenarios/10_Castle.cfg:51
#: Girl_unDead/scenarios/10_Castle.cfg:992
msgid "Randolf"
msgstr ""

#. [unit]: type=Free Mage, id=Mother
#: Girl_unDead/scenarios/10_Castle.cfg:62
msgid "Mother"
msgstr ""

#. [side]: id=King, type=Royal Warrior
#: Girl_unDead/scenarios/10_Castle.cfg:75
msgid "Vikren VII"
msgstr ""

#. [side]: id=King, type=Royal Warrior
#: Girl_unDead/scenarios/10_Castle.cfg:77
msgid "King of Wesnoth"
msgstr ""

#. [objective]: condition=win
#: Girl_unDead/scenarios/10_Castle.cfg:273
#: Girl_unDead/scenarios/10_Castle.cfg:1055
msgid "Defeat Randolf"
msgstr ""

#. [message]: speaker=Royal Mage
#: Girl_unDead/scenarios/10_Castle.cfg:369
msgid "My Lord, undead have come."
msgstr ""

#. [message]: speaker=King
#: Girl_unDead/scenarios/10_Castle.cfg:373
msgid "Ha, they are stupid. When I capture her, I shall be able to gain perpetual youth and immortality."
msgstr ""

#. [message]: speaker=Royal Mage
#: Girl_unDead/scenarios/10_Castle.cfg:377
msgid "Yes, my Lord. <small>Ha, you are the stupid one as well.</small>"
msgstr ""

#. [message]: speaker=King
#: Girl_unDead/scenarios/10_Castle.cfg:381
msgid "And as we gain more immortal mages, our plan will be fulfilled faster. Then we can eradicate all creatures of darkness."
msgstr ""

#. [message]: speaker=Royal Mage
#: Girl_unDead/scenarios/10_Castle.cfg:385
msgid "Yes, my Lord. <small>But you won't live to see it.</small>"
msgstr ""

#. [message]: speaker=Royal Mage
#: Girl_unDead/scenarios/10_Castle.cfg:389
msgid "<i>It was not easy to keep that annoying advisor away for the creation of Naia and the execution of this plot. But soon my wish shall be granted.</i>"
msgstr ""

#. [message]: speaker=Mother
#: Girl_unDead/scenarios/10_Castle.cfg:393
msgid "<small>Ah, Malica has come! Disaster awaits her, but I can't help her. Sorry, sorry Malica...</small>"
msgstr ""

#. [message]: speaker=Malica
#: Girl_unDead/scenarios/10_Castle.cfg:405
msgid "I've reached the castle, but I'm afraid to meet Mom because I am too ugly."
msgstr ""

#. [message]: speaker=Cyclos
#: Girl_unDead/scenarios/10_Castle.cfg:409
msgid "Don't worry. Your soul is very beautiful. And I think your mother must be very gentle and she loves you yet."
msgstr ""

#. [message]: speaker=Malica
#. [message]: speaker=Mother
#: Girl_unDead/scenarios/10_Castle.cfg:413
#: Girl_unDead/scenarios/10_Castle.cfg:665
msgid "Thank you, Cyclos."
msgstr ""

#. [message]: speaker=Poet
#: Girl_unDead/scenarios/10_Castle.cfg:417
msgid "There is nothing more beautiful than a bare skull."
msgstr ""

#. [message]: speaker=Poet
#: Girl_unDead/scenarios/10_Castle.cfg:421
msgid "My Princess, be careful. This castle is a labyrinth."
msgstr ""

#. [message]: speaker=Malica
#: Girl_unDead/scenarios/10_Castle.cfg:425
msgid "I see. Poet, why are you familiar with this castle?"
msgstr ""

#. [message]: speaker=Poet
#: Girl_unDead/scenarios/10_Castle.cfg:429
msgid "What? I can't hear you because of the noise."
msgstr ""

#. [message]: speaker=Malica
#: Girl_unDead/scenarios/10_Castle.cfg:507
msgid "Oh no! Our race has been burnt out by the sacred fire."
msgstr ""

#. [message]: speaker=Cyclos
#: Girl_unDead/scenarios/10_Castle.cfg:511
msgid "Even so... why were you not burned?"
msgstr ""

#. [message]: speaker=Hendrich
#: Girl_unDead/scenarios/10_Castle.cfg:515
msgid "I don't know why. But I feel you are closer to humans than undead."
msgstr ""

#. [message]: speaker=Poet
#: Girl_unDead/scenarios/10_Castle.cfg:523
msgid "Anyhow now we have to move forward, my Princess."
msgstr ""

#. [message]: speaker=Malica
#: Girl_unDead/scenarios/10_Castle.cfg:541
msgid "Oh, Mom!"
msgstr ""

#. [message]: speaker=Mother
#: Girl_unDead/scenarios/10_Castle.cfg:545
msgid "Malica! I've dreamed of you seeing you again."
msgstr ""

#. [message]: speaker=Royal Mage
#: Girl_unDead/scenarios/10_Castle.cfg:549
msgid "Ha ha ha... Such an impressive reunion. But listen, undead girl, your mother is now on our side. What are you going to do?"
msgstr ""

#. [message]: speaker=Royal Mage
#: Girl_unDead/scenarios/10_Castle.cfg:557
msgid "Gilgant, or Poet, you did a good job to bring the undead girl here."
msgstr ""

#. [message]: speaker=Poet
#: Girl_unDead/scenarios/10_Castle.cfg:561
msgid "Damn! I did it not for you. It's Malica's wish to come here."
msgstr ""

#. [message]: speaker=Malica
#: Girl_unDead/scenarios/10_Castle.cfg:565
msgid "What? Pleace explain for me, Poet."
msgstr ""

#. [message]: speaker=Royal Mage
#: Girl_unDead/scenarios/10_Castle.cfg:573
msgid "I will explain in his place. It was easy to find Varas, after he had disappeared. But, I don't catch him, but I've send a most faithful, most talented, and most brutal soldier as a spy to Varas. Because I wanted to not Varas but Veronica. The name of the spy is Gilgant, he is now called Poet. Come here, I will return you to original form."
msgstr ""

#. [message]: speaker=Malica
#: Girl_unDead/scenarios/10_Castle.cfg:577
msgid "No! It isn't truth, Poet!"
msgstr ""

#. [message]: speaker=Poet
#: Girl_unDead/scenarios/10_Castle.cfg:581
msgid "Yes... It's truth."
msgstr ""

#. [message]: speaker=Malica
#: Girl_unDead/scenarios/10_Castle.cfg:585
msgid "Oh..."
msgstr ""

#. [message]: speaker=Royal Mage
#: Girl_unDead/scenarios/10_Castle.cfg:589
msgid "Gilgant, Why did you stop report after we annihilated the village?"
msgstr ""

#. [message]: speaker=Poet
#: Girl_unDead/scenarios/10_Castle.cfg:593
msgid "I noticed that you were wrong, when I knew what happened the village. The King who must protect his people, harmed his people."
msgstr ""

#. [message]: speaker=Royal Mage
#: Girl_unDead/scenarios/10_Castle.cfg:597
msgid "Little evil is unavoidable for the greater good."
msgstr ""

#. [message]: speaker=Poet
#: Girl_unDead/scenarios/10_Castle.cfg:601
msgid "I can't understand highly political things, but I know you did it only for your interest."
msgstr ""

#. [message]: speaker=Royal Mage
#: Girl_unDead/scenarios/10_Castle.cfg:605
msgid "Do you against me? You shuld never return to human."
msgstr ""

#. [message]: speaker=Poet
#: Girl_unDead/scenarios/10_Castle.cfg:609
msgid "It's good!"
msgstr ""

#. [message]: speaker=Royal Mage
#: Girl_unDead/scenarios/10_Castle.cfg:613
msgid "So be it, then!"
msgstr ""

#. [message]: speaker=Royal Mage
#: Girl_unDead/scenarios/10_Castle.cfg:617
msgid "Young elf."
msgstr ""

#. [message]: speaker=Cyclos
#: Girl_unDead/scenarios/10_Castle.cfg:621
msgid "Me?"
msgstr ""

#. [message]: speaker=Royal Mage
#: Girl_unDead/scenarios/10_Castle.cfg:625
msgid "Yes, I teach you a good news. The undead who killed your father is in front of you."
msgstr ""

#. [message]: speaker=Cyclos
#: Girl_unDead/scenarios/10_Castle.cfg:629
msgid "What do you mean?"
msgstr ""

#. [message]: speaker=Royal Mage
#: Girl_unDead/scenarios/10_Castle.cfg:633
msgid "Gilgant, no Poet is the undead! Take revenge of your father with me."
msgstr ""

#. [message]: speaker=Cyclos
#: Girl_unDead/scenarios/10_Castle.cfg:637
msgid "Um..."
msgstr ""

#. [message]: speaker=Malica
#. [message]: speaker=Stella
#: Girl_unDead/scenarios/10_Castle.cfg:645
#: Girl_unDead/scenarios/10_Castle.cfg:649
msgid "Cyclos..."
msgstr ""

#. [message]: speaker=Mother
#: Girl_unDead/scenarios/10_Castle.cfg:653
msgid "Cyclos, please help my daughter. Defeat Randolf. Never mind for me."
msgstr ""

#. [message]: speaker=Malica
#: Girl_unDead/scenarios/10_Castle.cfg:657
#: Girl_unDead/scenarios/10_Castle.cfg:785
msgid "Mom!"
msgstr ""

#. [message]: speaker=Cyclos
#: Girl_unDead/scenarios/10_Castle.cfg:661
msgid "Randolf, I defeat you with Malica. I never lose whom I love any more."
msgstr ""

#. [message]: speaker=Royal Mage
#: Girl_unDead/scenarios/10_Castle.cfg:673
#: Girl_unDead/scenarios/10_Castle.cfg:685
msgid "You are fool to fight against me!"
msgstr ""

#. [message]: speaker=unit
#: Girl_unDead/scenarios/10_Castle.cfg:695
msgid "My attack has no effect."
msgstr ""

#. [message]: speaker=Royal Mage
#: Girl_unDead/scenarios/10_Castle.cfg:699
msgid "Fool, I am invincible so long as the woman lives."
msgstr ""

#. [message]: speaker=Mother
#: Girl_unDead/scenarios/10_Castle.cfg:703
msgid "Malica, you must kill me! The King intends to make a second sun! If he does so, the balance of the world will be shattered."
msgstr ""

#. [message]: speaker=Malica
#: Girl_unDead/scenarios/10_Castle.cfg:707
msgid "No! I can't kill you!"
msgstr ""

#. [message]: speaker=Mother
#: Girl_unDead/scenarios/10_Castle.cfg:711
msgid "Only a kinsman of mine is able to kill me. That is you and no one else. Now, be quick about it!"
msgstr ""

#. [objective]: condition=win
#: Girl_unDead/scenarios/10_Castle.cfg:715
msgid "Defeat Mother by Malica"
msgstr ""

#. [message]: speaker=Royal Mage
#: Girl_unDead/scenarios/10_Castle.cfg:752
msgid "Ha, no one can hurt me!"
msgstr ""

#. [message]: speaker=Malica
#: Girl_unDead/scenarios/10_Castle.cfg:770
msgid "Ah, sorry, sorry Mom..."
msgstr ""

#. [message]: speaker=Mother
#: Girl_unDead/scenarios/10_Castle.cfg:774
msgid "Malica, it's alright. I thank you. Good bye, Malica."
msgstr ""

#. [message]: speaker=Malica
#: Girl_unDead/scenarios/10_Castle.cfg:789
msgid "Mage Randolf, you are no longer immortal. Surrender or die!"
msgstr ""

#. [message]: speaker=Royal Mage
#: Girl_unDead/scenarios/10_Castle.cfg:793
msgid "Ha ha ha! The heads of undead are certainly empty. Haven't you noticed, little girl, that you are already mine?"
msgstr ""

#. [message]: speaker=Malica
#: Girl_unDead/scenarios/10_Castle.cfg:797
msgid "What? Oh! I can't move my body..."
msgstr ""

#. [message]: speaker=Poet
#: Girl_unDead/scenarios/10_Castle.cfg:838
msgid "Argh! My Princess no longer belongs to the night. Randolf, what did you do to Malica?"
msgstr ""

#. [message]: speaker=Royal Mage
#: Girl_unDead/scenarios/10_Castle.cfg:842
msgid "She is now my captive, as her mother was. Her gift of life is just as strong as her mother's was. And since she has no family, no one can kill her. Now I am immortal too."
msgstr ""

#. [message]: speaker=Malica
#: Girl_unDead/scenarios/10_Castle.cfg:846
msgid "Ah, you Great Mage, although you appear young, your head is empty because you have lived too long."
msgstr ""

#. [message]: speaker=Poet
#: Girl_unDead/scenarios/10_Castle.cfg:850
msgid "Did I mishear it? It sounded like my Princess just spoke out her venomous tongue."
msgstr ""

#. [message]: speaker=Royal Mage
#: Girl_unDead/scenarios/10_Castle.cfg:854
msgid "Huh? What do you mean?"
msgstr ""

#. [message]: speaker=Malica
#: Girl_unDead/scenarios/10_Castle.cfg:858
msgid "My heart is bleeding because of you. But I do have a brother... Cyclos, kill me!"
msgstr ""

#. [message]: speaker=Cyclos
#: Girl_unDead/scenarios/10_Castle.cfg:862
msgid "Malica?!"
msgstr ""

#. [message]: speaker=Malica
#: Girl_unDead/scenarios/10_Castle.cfg:866
msgid "Your father was my father. Look at this earring. I know you possess its match."
msgstr ""

#. [message]: speaker=Cyclos
#: Girl_unDead/scenarios/10_Castle.cfg:870
msgid "I have been wondering... But I cannot kill my sister!"
msgstr ""

#. [message]: speaker=Malica
#: Girl_unDead/scenarios/10_Castle.cfg:874
msgid "My body was destroyed long ago. It is fated that my life disappear completely, just as it was for my mother. Cyclos, please!"
msgstr ""

#. [message]: speaker=Cyclos
#: Girl_unDead/scenarios/10_Castle.cfg:878
msgid "All... right..."
msgstr ""

#. [objective]: condition=win
#: Girl_unDead/scenarios/10_Castle.cfg:882
msgid "Defeat Malica by Cyclos"
msgstr ""

#. [message]: speaker=Cyclos
#: Girl_unDead/scenarios/10_Castle.cfg:954
msgid "Ah, Malica! My sister! Sorry, sorry..."
msgstr ""

#. [message]: speaker=Malica
#: Girl_unDead/scenarios/10_Castle.cfg:958
msgid "Cyclos. It's alright. Now, I can be with Mom again. Bye Cyclos, I love you."
msgstr ""

#. [message]: speaker=Cyclos
#: Girl_unDead/scenarios/10_Castle.cfg:969
msgid "Malica!"
msgstr ""

#. [message]: speaker=Cyclos
#: Girl_unDead/scenarios/10_Castle.cfg:973
msgid "Randolf! I kill you. I never forgive you."
msgstr ""

#. [message]: speaker=Royal Mage
#: Girl_unDead/scenarios/10_Castle.cfg:977
msgid "Ha, you are ridiculous, boy... Uh! What is happening to my body?"
msgstr ""

#. [message]: speaker=Rotten Mage
#: Girl_unDead/scenarios/10_Castle.cfg:999
msgid "No! No..."
msgstr ""

#. [message]: speaker=Cyclos
#: Girl_unDead/scenarios/10_Castle.cfg:1003
msgid "He has become repulsive to look at."
msgstr ""

#. [message]: speaker=Poet
#: Girl_unDead/scenarios/10_Castle.cfg:1007
msgid "That is because his soul was eaten by desire."
msgstr ""

#. [message]: role=mage
#: Girl_unDead/scenarios/10_Castle.cfg:1031
msgid "Oh, there is a monster!"
msgstr ""

#. [message]: role=Kingdom
#: Girl_unDead/scenarios/10_Castle.cfg:1041
msgid "Kill it quickly!"
msgstr ""

#. [message]: speaker=unit
#: Girl_unDead/scenarios/10_Castle.cfg:1091
#: Girl_unDead/utils/deaths.cfg:15
msgid "I can no more go... I'm sorry, good bye."
msgstr ""

#. [message]: speaker=Poet
#: Girl_unDead/scenarios/10_Castle.cfg:1095
#: Girl_unDead/utils/deaths.cfg:19
msgid "My Princess, don't say sorry! Don't say good bye..."
msgstr ""

#. [message]: speaker=$unit.id
#: Girl_unDead/scenarios/10_Castle.cfg:1128
msgid "Die, monster!"
msgstr ""

#. [message]: speaker=Rotten Mage
#: Girl_unDead/scenarios/10_Castle.cfg:1132
msgid "No! I'm Randolf, your Royal Mage!"
msgstr ""

#. [message]: speaker=Cyclos
#: Girl_unDead/scenarios/10_Castle.cfg:1136
msgid "Stop! I will kill him myself!"
msgstr ""

#. [message]: speaker=Rotten Mage
#: Girl_unDead/scenarios/10_Castle.cfg:1148
msgid "Alas! I was meant to be filled with the light of all the world, not this..."
msgstr ""

#. [message]: speaker=Rotten Mage
#: Girl_unDead/scenarios/10_Castle.cfg:1152
msgid "But you are too late... Naia has already..."
msgstr ""

#. [message]: speaker=Cyclos
#: Girl_unDead/scenarios/10_Castle.cfg:1162
msgid "He is dead, the one who took from me all whom I loved. He died too easily... You, the men who aided him! I will kill all of you!"
msgstr ""

#. [message]: speaker=Stella
#: Girl_unDead/scenarios/10_Castle.cfg:1166
msgid "Cyclos! Stop! Stop!"
msgstr ""

#. [message]: speaker=Poet
#: Girl_unDead/scenarios/10_Castle.cfg:1170
msgid "He is dangerous, deranged. We must move away from him!"
msgstr ""

#. [message]: speaker=King
#: Girl_unDead/scenarios/10_Castle.cfg:1216
msgid "Randolf, why aren't you helping me?"
msgstr ""

#. [message]: speaker=Royal Mage
#: Girl_unDead/scenarios/10_Castle.cfg:1220
msgid "Stupid Vikren, many men can take your place, but I am special."
msgstr ""

#. [message]: speaker=King
#: Girl_unDead/scenarios/10_Castle.cfg:1224
msgid "Guards, kill Randolf!"
msgstr ""

#. [message]: speaker=Royal Mage
#: Girl_unDead/scenarios/10_Castle.cfg:1228
msgid "Do you forget I am immortal? Stupid one..."
msgstr ""

#. [scenario]: id=10x_Epilogue
#: Girl_unDead/scenarios/10x_Epilogue.cfg:5
msgid "Epilogue"
msgstr ""

#. [message]: speaker=Stella
#: Girl_unDead/scenarios/10x_Epilogue.cfg:63
msgid "Thank you, Poet. I now look kindly upon you."
msgstr ""

#. [message]: speaker=Poet
#: Girl_unDead/scenarios/10x_Epilogue.cfg:67
msgid "I did only what I wanted to do. I did not do it for you."
msgstr ""

#. [message]: speaker=Stella
#: Girl_unDead/scenarios/10x_Epilogue.cfg:71
msgid "We shall reach our home tomorrow, but you must not accompany us to the village."
msgstr ""

#. [message]: speaker=Poet
#: Girl_unDead/scenarios/10x_Epilogue.cfg:75
msgid "I understand. To tell the truth, I don't like elves."
msgstr ""

#. [message]: speaker=Stella
#: Girl_unDead/scenarios/10x_Epilogue.cfg:79
msgid "Ha ha ha, to tell the truth, it is difficult to spend time with you. Still, I will feel lonely without you. Where will you go?"
msgstr ""

#. [message]: speaker=Poet
#: Girl_unDead/scenarios/10x_Epilogue.cfg:83
msgid "Somewhere desolate."
msgstr ""

#. [message]: speaker=Stella
#: Girl_unDead/scenarios/10x_Epilogue.cfg:110
msgid "I believe this troll will follow you."
msgstr ""

#. [message]: speaker=Poet
#: Girl_unDead/scenarios/10x_Epilogue.cfg:114
msgid "I do not think he will. It was Malica he followed."
msgstr ""

#. [message]: speaker=Poet
#: Girl_unDead/scenarios/10x_Epilogue.cfg:135
msgid "What are you going to do now?"
msgstr ""

#. [message]: speaker=Stella
#: Girl_unDead/scenarios/10x_Epilogue.cfg:139
msgid "I will take care of Cyclos."
msgstr ""

#. [message]: speaker=Poet
#: Girl_unDead/scenarios/10x_Epilogue.cfg:143
msgid "Indeed, he needs help, but that may be difficult."
msgstr ""

#. [message]: speaker=Stella
#: Girl_unDead/scenarios/10x_Epilogue.cfg:147
msgid "I know. So, I have a request of you before you depart."
msgstr ""

#. [message]: speaker=Stella
#: Girl_unDead/scenarios/10x_Epilogue.cfg:155
msgid "Please cut off my cursed right arm. I cannot return home with it."
msgstr ""

#. [message]: speaker=Poet
#: Girl_unDead/scenarios/10x_Epilogue.cfg:159
msgid "No! I can't! You will need both arms to help. But you must hide the secret until you die."
msgstr ""

#. [message]: speaker=Poet
#: Girl_unDead/scenarios/10x_Epilogue.cfg:167
msgid "Sorry. I have come to hate killing and maiming. Being with Malica has changed me. I'm now of no use to the undead."
msgstr ""

#. [message]: speaker=Cyclos
#: Girl_unDead/scenarios/10x_Epilogue.cfg:195
msgid "Stella! Come! Stella!"
msgstr ""

#. [message]: speaker=Poet
#: Girl_unDead/scenarios/10x_Epilogue.cfg:212
msgid "Oh, he acts like a baby. Stella, you will have a hard life."
msgstr ""

#. [message]: speaker=Stella
#: Girl_unDead/scenarios/10x_Epilogue.cfg:216
msgid "I know."
msgstr ""

#. [message]: speaker=Poet
#: Girl_unDead/scenarios/10x_Epilogue.cfg:220
msgid "Cry when you feel the need to cry. Seek not to defeat weakness, but love weakness."
msgstr ""

#. [message]: speaker=Stella
#: Girl_unDead/scenarios/10x_Epilogue.cfg:224
msgid "I cannot understand what you say."
msgstr ""

#. [message]: speaker=Poet
#: Girl_unDead/scenarios/10x_Epilogue.cfg:228
msgid "Then forget it. I am a philosopher, not a poet."
msgstr ""

#. [message]: speaker=Stella
#: Girl_unDead/scenarios/10x_Epilogue.cfg:232
msgid "Ha ha ha, thank you anyway."
msgstr ""

#. [message]: speaker=Poet
#: Girl_unDead/scenarios/10x_Epilogue.cfg:236
msgid "Night has fallen. You must go to the baby Cyclos. I say... good bye."
msgstr ""

#. [message]: speaker=Stella
#: Girl_unDead/scenarios/10x_Epilogue.cfg:253
msgid "Good bye."
msgstr ""

#. [message]: speaker=Cyclos
#: Girl_unDead/scenarios/10x_Epilogue.cfg:283
msgid "Stella! Where are you?"
msgstr ""

