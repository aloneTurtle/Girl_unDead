#: Girl_unDead/scenarios/00_Death.cfg:5
msgid "Death"
msgstr ""

#. [scenario]: id=00_Death
#: Girl_unDead/scenarios/00_Death.cfg:20
msgid "Why did you come closer? Hey, go away!"
msgstr ""

#. [scenario]: id=00_Death
#: Girl_unDead/scenarios/00_Death.cfg:21
msgid "You stranger's kid, don't bother me!"
msgstr ""

#. [scenario]: id=00_Death
#: Girl_unDead/scenarios/00_Death.cfg:22
msgid "Hey, you are dangerous! Get the hell lost!"
msgstr ""

#. [scenario]: id=00_Death
#: Girl_unDead/scenarios/00_Death.cfg:24
msgid "I would never play with you because my Mom says you're not a human being like us. Come on, guys, let's quickly go!"
msgstr ""

